      { "key": "logs:view", "name": "查看审计日志（只读）", "module": "日志审计", "path": "/logs" },

      { "key": "settings:view", "name": "查看系统设置", "module": "系统设置", "path": "/settings" },
      { "key": "settings:version:read", "name": "查看版本策略", "module": "系统设置", "path": "/settings/versions" },
